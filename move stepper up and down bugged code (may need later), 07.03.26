/* =========================================================================
 * INTERPLANETARY ROBOT - AUTONOMOUS STATE MACHINE
 * Full Mission: Init -> Hunt -> Grab -> Lift -> Turn -> Square Up -> Release
 * ========================================================================= */

#include <Wire.h>
#include <MobaTools.h>

// ==========================================
// 1. PIN & ADDRESS DEFINITIONS
// ==========================================
#define MD25ADDRESS 0x58
#define SPEED1 (byte)0x00
#define SPEED2 0x01
#define ENCODERONE 0x02
#define ENCODERTWO 0x06
#define RESETENCODERS 0x10
#define MODESELECTOR 0xF

#define trigLeft 3            
#define echoLeft 2            
#define trigRight 9           
#define echoRight 8           
#define ledPin 12             
#define SERVO_PIN 10          

const int dirPin    = 4;      // Direction pin (LOW = UP, HIGH = DOWN)
const int stepPin   = 5;      
const int enablePin = 6;      

// ==========================================
// 2. TUNING CONSTANTS
// ==========================================
const int STOP           = 128; 
const int BASE_SPEED     = 25;  
const int TURN_SPEED     = 18;  
const int REV_WALL_SPEED = 15;  // Speed for reversing into the wall

const int SCAN_DIST      = 100; 
const int GRAB_DIST      = 18;  
const int TICKS_90_DEG   = 170; 

const float TICKS_PER_MM = 1.0; 

// Gripper
int currentAngle       = 180;   
const int CLOSE_ANGLE  = 140;   
const int OPEN_ANGLE   = 180;
const int SERVO_SPEED  = 10;    

// --- STEPPER & LEAD SCREW MATH ---
const int STEPS_PER_REV    = 400; // 400 steps = 3mm travel
const float MM_PER_REV     = 3.0; 
const float STEPS_PER_MM   = STEPS_PER_REV / MM_PER_REV; 

const float LIFT_HEIGHT_MM = 60.0; // Total height to travel
const long LIFT_STEPS = (long)(LIFT_HEIGHT_MM * STEPS_PER_MM); 

// ==========================================
// 3. OBJECTS & STATE MACHINE
// ==========================================
MoToServo gripperServo; 

enum RobotState {
  STATE_STARTUP,
  STATE_MOVE_TO_BOX,
  STATE_SWEEP,
  STATE_APPROACH,
  STATE_OPEN_CLAWS,
  STATE_BLIND_APPROACH,
  STATE_GRAB_CAN,
  STATE_READY_TO_LIFT,
  STATE_TURN_90_CW,
  STATE_REVERSE_TO_WALL,  // New State: Squaring up
  STATE_RELEASE_CAN,      // New State: Resetting lead screw & dropping can
  STATE_COMPLETE
};

RobotState currentState = STATE_STARTUP;

// ==========================================
// 4. SETUP
// ==========================================
void setup() {
  Serial.begin(9600); 
  Wire.begin();       

  pinMode(trigLeft,  OUTPUT); pinMode(echoLeft,  INPUT);
  pinMode(trigRight, OUTPUT); pinMode(echoRight, INPUT);
  pinMode(ledPin, OUTPUT);

  pinMode(stepPin,   OUTPUT);
  pinMode(dirPin,    OUTPUT);
  pinMode(enablePin, OUTPUT);
  digitalWrite(enablePin, HIGH); 

  gripperServo.attach(SERVO_PIN);
  gripperServo.setSpeed(SERVO_SPEED); 
  
  delay(2000); // Phase 1 Delay
  slowServoMove(OPEN_ANGLE);
  delay(500); 
  slowServoMove(CLOSE_ANGLE);

  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(MODESELECTOR); 
  Wire.write(0);            
  Wire.endTransmission();

  encoderReset(); 
  Serial.println("SYSTEM READY.");
}

// ==========================================
// 5. MAIN LOOP
// ==========================================
void loop() {
  switch (currentState) {

    case STATE_STARTUP:
      encoderReset();
      delay(100); 
      currentState = STATE_MOVE_TO_BOX; 
      break;

    case STATE_MOVE_TO_BOX:
      if (driveDistance(600, BASE_SPEED)) { 
        currentState = STATE_SWEEP; 
      }
      break;

    case STATE_SWEEP:
      set_speed(STOP + TURN_SPEED, STOP - TURN_SPEED);
      if (checkForObject()) {
        set_speed(STOP, STOP);
        delay(500); 
        currentState = STATE_APPROACH; 
      }
      break;

    case STATE_APPROACH:
      if (performDifferentialApproach()) {
        set_speed(STOP, STOP);
        encoderReset();
        currentState = STATE_OPEN_CLAWS; 
      }
      break;

    case STATE_OPEN_CLAWS:
      delay(300);
      slowServoMove(OPEN_ANGLE); 
      delay(500);         
      currentState = STATE_BLIND_APPROACH;
      break;

    case STATE_BLIND_APPROACH:
      if (driveDistance(150, BASE_SPEED)) {
        currentState = STATE_GRAB_CAN;
      }
      break;

    case STATE_GRAB_CAN:
      delay(300);
      slowServoMove(CLOSE_ANGLE);
      delay(500); 
      currentState = STATE_READY_TO_LIFT;
      break;

    case STATE_READY_TO_LIFT:
      set_speed(STOP, STOP); 
      moveStepperUp(LIFT_STEPS);
      digitalWrite(ledPin, HIGH);
      delay(500);
      digitalWrite(ledPin, LOW);
      encoderReset();
      delay(100); 
      currentState = STATE_TURN_90_CW;
      break;

    case STATE_TURN_90_CW:
      if (turn(TICKS_90_DEG, TURN_SPEED, true)) {
        Serial.println("Turn Complete. Reversing to wall...");
        currentState = STATE_REVERSE_TO_WALL;
      }
      break;

    case STATE_REVERSE_TO_WALL:
      // Reverse blindly for 2 seconds to square against the wall
      set_speed(STOP - REV_WALL_SPEED, STOP - REV_WALL_SPEED);
      delay(2000); 
      set_speed(STOP, STOP);
      delay(500);
      Serial.println("Chassis squared. Releasing can...");
      currentState = STATE_RELEASE_CAN;
      break;

    case STATE_RELEASE_CAN:
      // Reset Lead Screw: Move DOWN the same amount we went UP
      moveStepperDown(LIFT_STEPS);
      delay(500);
      // Open Gripper
      slowServoMove(OPEN_ANGLE);
      Serial.println("Can released. Mission Complete.");
      currentState = STATE_COMPLETE;
      break;

    case STATE_COMPLETE:
      set_speed(STOP, STOP);
      break;
  }
}

// ==========================================
// 6. HELPER FUNCTIONS
// ==========================================

void slowServoMove(int targetAngle) {
  currentAngle = targetAngle;
  gripperServo.write(targetAngle); 
  while (gripperServo.moving() > 0) {
    delay(10); 
  }
}

bool driveDistance(long distanceMM, int speed) {
  long target = distanceMM * TICKS_PER_MM; 
  if (abs(getEncoder()) < target) {
    set_speed(STOP + speed, STOP + speed); 
    return false;
  } else {
    set_speed(STOP, STOP); 
    encoderReset();        
    return true;  
  }
}

bool turn(long ticks, int speed, bool clockwise) {
  if (abs(getEncoder()) < ticks) {
    if (clockwise) {
      set_speed(STOP + speed, STOP - speed);
    } else {
      set_speed(STOP - speed, STOP + speed);
    }
    return false;
  } else {
    set_speed(STOP, STOP);
    encoderReset();
    return true;
  }
}

bool checkForObject() {
  int dL = readSensor(trigLeft, echoLeft); 
  delay(20);                               
  int dR = readSensor(trigRight, echoRight); 
  if ((dL > 2 && dL < SCAN_DIST) || (dR > 2 && dR < SCAN_DIST)) {
    return true; 
  }
  return false; 
}

bool performDifferentialApproach() {
  int dL = readSensor(trigLeft, echoLeft);
  delay(20); 
  int dR = readSensor(trigRight, echoRight);
  if ((dL > 0 && dL <= GRAB_DIST) || (dR > 0 && dR <= GRAB_DIST)) {
    return true; 
  }
  int error      = dL - dR;
  int leftMotor  = BASE_SPEED;
  int rightMotor = BASE_SPEED;
  if (dL > SCAN_DIST && dR < SCAN_DIST) {
    leftMotor  = BASE_SPEED + 10;
    rightMotor = BASE_SPEED - 15;
  } else if (dR > SCAN_DIST && dL < SCAN_DIST) {
    leftMotor  = BASE_SPEED - 15;
    rightMotor = BASE_SPEED + 10;
  } else if (dL < SCAN_DIST && dR < SCAN_DIST) {
    int steeringAdjust = constrain((int)(error * 1.2), -20, 20); 
    leftMotor  = BASE_SPEED + steeringAdjust;
    rightMotor = BASE_SPEED - steeringAdjust;
  } else {
    leftMotor  = BASE_SPEED - 5;
    rightMotor = BASE_SPEED - 5;
  }
  set_speed(STOP + leftMotor, STOP + rightMotor);
  return false; 
}

void moveStepperUp(long steps) {
  digitalWrite(enablePin, LOW); 
  digitalWrite(dirPin, LOW);    // LOW = UP
  delay(50); 
  for (long i = 0; i < steps; i++) {
    digitalWrite(stepPin, HIGH); delayMicroseconds(1500); 
    digitalWrite(stepPin, LOW);  delayMicroseconds(1500); 
  }
  delay(50); 
  digitalWrite(enablePin, HIGH); 
}

void moveStepperDown(long steps) {
  digitalWrite(enablePin, LOW); 
  digitalWrite(dirPin, HIGH);   // HIGH = DOWN
  delay(50); 
  for (long i = 0; i < steps; i++) {
    digitalWrite(stepPin, HIGH); delayMicroseconds(1500);
    digitalWrite(stepPin, LOW);  delayMicroseconds(1500);
  }
  delay(50); 
  digitalWrite(enablePin, HIGH); 
}

int readSensor(int trig, int echo) {
  digitalWrite(trig, LOW);  delayMicroseconds(2);
  digitalWrite(trig, HIGH); delayMicroseconds(10);
  digitalWrite(trig, LOW);
  long duration = pulseIn(echo, HIGH, 30000);
  if (duration == 0) return 999;
  return duration * 0.034 / 2; 
}

void set_speed(int s1, int s2) {
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(SPEED1); Wire.write(constrain(s1, 0, 255)); 
  Wire.endTransmission();
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(SPEED2); Wire.write(constrain(s2, 0, 255));
  Wire.endTransmission();
}

void encoderReset() {
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(RESETENCODERS); Wire.write(0x20); 
  Wire.endTransmission();
}

long getEncoder() {
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(ENCODERONE); 
  Wire.endTransmission();
  Wire.requestFrom(MD25ADDRESS, 4);
  if (Wire.available() < 4) return 0; 
  long pos  = (long)Wire.read() << 24;
  pos      += (long)Wire.read() << 16;
  pos      += (long)Wire.read() << 8;
  pos      += (long)Wire.read();
  return pos;
}
